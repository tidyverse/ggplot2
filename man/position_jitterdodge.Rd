# Fixed: explicit group aligns points with boxes
ggplot(df, aes(x, y, fill = fill_var)) +
  geom_boxplot(outlier.shape = NA) +
  geom_point(
    aes(colour = colour_var, group = fill_var),
    position = position_jitterdodge()
  )
}
